# Ejemplo de variables de entorno para frontend (Vite)
# Copia a frontend/.env.local o frontend/.env durante el desarrollo

# URL base de la API backend
VITE_API_URL=http://localhost:3001

# NOTA: el modo test automático por query string fue eliminado.
# Si en algún CI necesitas una bandera, crea tu propio endpoint de testing o usa mocks.
# VITE_TEST_MODE=true  # opcional, solo si implementas soporte controlado
