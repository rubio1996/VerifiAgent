# Ejemplo de variables de entorno para backend
# Copia este archivo a .env y completa los valores antes de ejecutar en desarrollo o producción

# Database
# Para desarrollo local (SQLite):
# DATABASE_URL=file:./dev.db
# Para producción (Postgres):
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/verifid

# JWT
JWT_SECRET=replace_with_a_strong_secret_min_32_chars

# Keys y APIS
GROQ_API_KEY=
OPENSANCTIONS_API_KEY=
EMAIL_API_KEY=

# Puerto de la API
PORT=3001

# URL del frontend (útil para CORS, enlaces en emails, etc.)
FRONTEND_URL=http://localhost:5173
